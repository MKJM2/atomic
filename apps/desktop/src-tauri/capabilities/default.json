{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for twoline desktop",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "sql:default",
    "notification:default",
    "log:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$APP_LOG_DIR/**"
        },
        {
          "path": "/**"
        }
      ]
    },
    "sql:allow-execute"
  ]
}