{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atomic",
  "version": "0.1.0",
  "identifier": "app.atomic.journal",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Atomic",
        "width": 800,
        "height": 600,
        "hiddenTitle": true,
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; connect-src 'self' tauri:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxRkY1NDIxQTRGRDFBQkUKUldTK0d2MmtJVlQvTVpyTGV4RG82MXlmTWNGSEpRUloxK2pxTDhVaVA4c1AxbjBjam8xdVZpbEYK",
      "endpoints": [
        "https://github.com/mkurek/atomic/releases/latest/download/latest.json"
      ]
    }
  }
}